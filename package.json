{
  "name": "helyx",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "bun main.ts",
    "dev": "bun --watch main.ts",
    "migrate": "bun memory/db.ts",
    "cli": "bun cli.ts",
    "test": "bun test tests/unit/",
    "test:unit": "bun test tests/unit/",
    "test:e2e": "cd tests && npx playwright test --config=playwright.config.ts",
    "test:e2e:api": "cd tests && npx playwright test --config=playwright.config.ts --project=api",
    "test:e2e:dashboard": "cd tests && npx playwright test --config=playwright.config.ts --project=dashboard",
    "test:coverage": "bun test --coverage tests/unit/",
    "cleanup:dry-run": "DRY_RUN=true bun cleanup/runner.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "grammy": "^1.35.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
