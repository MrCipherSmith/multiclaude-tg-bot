# Telegram
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use the bot
# Required unless ALLOW_ALL_USERS=true — bot refuses to start if both are unset
ALLOWED_USERS=
# Set to true to allow ALL Telegram users (⚠ only for trusted private deployments)
# ALLOW_ALL_USERS=true

# LLM Provider for standalone mode (pick one, checked in order):
#
# Option 1: Anthropic (best quality)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=8192
#
# Option 2: Google AI (free tier, Gemma 4 models)
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemma-4-31b-it
#
# Option 3: OpenRouter (many models, free & paid)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-235b-a22b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#
# Option 4: Ollama (local, free, set OLLAMA_CHAT_MODEL)
OLLAMA_CHAT_MODEL=qwen3:8b

# PostgreSQL (with pgvector extension)
# For docker-compose: postgres://helyx:helyx_secret@postgres:5432/helyx
# For local:          postgres://helyx:your_password@localhost:5432/helyx
DATABASE_URL=postgres://helyx:helyx_secret@postgres:5432/helyx
POSTGRES_PASSWORD=helyx_secret

# Ollama (for local embeddings)
# For docker-compose: http://ollama:11434
# For local:          http://localhost:11434
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text
# Optional: use a local Ollama model for summarization (cheaper, offline)
# Leave empty to use the main LLM provider (ANTHROPIC_API_KEY etc.)
# SUMMARIZE_MODEL=gemma4:e4b

# Voice transcription (optional)
# Primary: Groq (free, fast, whisper-large-v3) — get key at https://console.groq.com
GROQ_API_KEY=
# Fallback: local Whisper ASR
# For docker-compose: http://whisper:9000
# For local:          http://localhost:9000
WHISPER_URL=http://localhost:9000

# TTS (text-to-speech for voice replies)
# Provider: "yandex" | "kokoro" | "auto" (default: auto = yandex if keys set, else kokoro)
TTS_PROVIDER=auto
# Yandex SpeechKit (best Russian support, requires API key)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_VOICE=alena       # alena | filipp | jane | omazh | zahar | ermil
YANDEX_LANG=ru-RU
# Kokoro local TTS (offline, English only, ~82M ONNX model)
KOKORO_DTYPE=q8           # q4 | q8 | fp16 | fp32
KOKORO_VOICE=af_bella     # af_bella | af_heart | am_adam | am_michael | bf_emma | bm_george
HF_TOKEN=                 # Required for first-time model download from HuggingFace (free account)

# Server
PORT=3847
SHORT_TERM_WINDOW=20
IDLE_TIMEOUT_MS=900000

# Security
TELEGRAM_WEBHOOK_SECRET=  # REQUIRED in webhook mode — generate with: openssl rand -hex 32
# JWT_SECRET=         # Custom JWT signing secret (auto-derived from bot token if not set)
# SECURE_COOKIES=true # Force Secure flag on cookies (auto-detected from webhook URL)

# Knowledge base (optional — enables /skills and /rules commands)
# Path to directory containing AGENTS.md with skills/rules catalog
# KNOWLEDGE_BASE=/path/to/knowledge-base

# Docker volume mounts
# Directory on the host containing your bot/project directories (mounted read-only)
# Default: $HOME/bots — override if your projects live elsewhere
# HOST_PROJECTS_DIR=/home/user/projects

# --- Hermes Skills Toolkit Phase A (inline shell expansion) ---
# HELYX_SHELL_TIMEOUT_MS=5000   # per-command timeout (ms)
# HELYX_SHELL_OUTPUT_CAP=4096   # max stdout chars per command

# --- Hermes Skills Toolkit Phase C (autonomous skill creation) ---
# HELYX_AUX_LLM_PROVIDER=deepseek   # deepseek | ollama | openrouter
# HELYX_AUX_LLM_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=                 # required if provider=deepseek
# CUSTOM_OPENAI_BASE_URL=https://api.deepseek.com
# HELYX_OLLAMA_URL=http://localhost:11434

# --- Hermes Skills Toolkit Phase B (skill curator) ---
# HELYX_CURATOR_CRON=0 3 * * 0     # default: Sundays 03:00 UTC (DOW + H + M only)
# HELYX_CURATOR_PAUSED=false       # set to true to skip all curator runs
# HELYX_CURATOR_ARCHIVE_DAYS=90    # auto-archive idle threshold
# HELYX_CURATOR_PIN_USE_COUNT=10   # auto-pin use_count threshold
# SUPERVISOR_CHAT_ID=              # Telegram chat for curator summaries / approvals
# SUPERVISOR_TOPIC_ID=             # forum topic id (optional)
