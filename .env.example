# Telegram
TELEGRAM_BOT_TOKEN=
ALLOWED_USERS=

# LLM Provider for standalone mode (pick one, checked in order):
#
# Option 1: Anthropic (best quality)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=8192
#
# Option 2: OpenRouter (free models available)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-235b-a22b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#
# Option 3: Ollama (local, free, set OLLAMA_CHAT_MODEL)
OLLAMA_CHAT_MODEL=qwen3:8b

# PostgreSQL (with pgvector extension)
# For docker-compose: postgres://claude_bot:claude_bot_secret@postgres:5432/claude_bot
# For local:          postgres://claude_bot:your_password@localhost:5432/claude_bot
DATABASE_URL=postgres://claude_bot:claude_bot_secret@postgres:5432/claude_bot
POSTGRES_PASSWORD=claude_bot_secret

# Ollama (for local embeddings)
# For docker-compose: http://ollama:11434
# For local:          http://localhost:11434
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text

# Whisper (optional — for voice message transcription)
# For docker-compose: http://whisper:9000
# For local:          http://localhost:9000
WHISPER_URL=http://localhost:9000

# Server
PORT=3847
SHORT_TERM_WINDOW=20
IDLE_TIMEOUT_MS=900000
